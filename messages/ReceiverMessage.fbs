include "Error.fbs";
include "Ready.fbs";
include "Results.fbs";
include "Stop.fbs";

namespace sacndeathray.message;

union ReceiverMessageVal {
    Error,
    Ready,
    Results,
    Stop,
}

table ReceiverMessage {
    timestamp:string (required);
    val:ReceiverMessageVal (required);
}

root_type ReceiverMessage;
